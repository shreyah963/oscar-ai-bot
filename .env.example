# OSCAR Configuration
# Copy this file to .env and uncomment any values you want to override.
# All values shown are the defaults — uncomment only what you need to change.
#
# Sensitive values (Slack tokens, user IDs, channel IDs) go in AWS Secrets Manager.
# See the bottom of this file for details.

# ============================================================
# JENKINS AGENT
# ============================================================
# JENKINS_URL=https://build.ci.opensearch.org
# JENKINSFILE_GITHUB_REPO=opensearch-project/opensearch-build
# JENKINSFILE_GITHUB_BRANCH=main
# JENKINS_VERIFY_SSL=true
# JENKINSFILE_IGNORE_LIST=

# ============================================================
# FEATURE FLAGS
# ============================================================
# ENABLE_DM=false

# ============================================================
# AGENT TIMEOUTS & THREAD POOL
# ============================================================
# CONTEXT_TTL=604800
# AGENT_TIMEOUT=90
# AGENT_MAX_RETRIES=2
# HOURGLASS_THRESHOLD_SECONDS=45
# TIMEOUT_THRESHOLD_SECONDS=120
# MAX_WORKERS=100
# MAX_ACTIVE_QUERIES=100
# MONITOR_INTERVAL_SECONDS=15
# SLACK_HANDLER_THREAD_NAME_PREFIX=oscar-agent

# ============================================================
# AGENT QUERY TEMPLATES (used by slash commands)
# ============================================================
# AGENT_QUERY_ANNOUNCE=Send a release announcement message to channel {channel} using the release-announcement template for version {version} {rc_param}. Ensure the template is filled out correctly.
# AGENT_QUERY_ASSIGN_OWNER=Send a release owner assignment message to channel {channel} using the release-owner-assignment template for version {version} {rc_param}. Make sure to ping any relevant people and ensure the template is filled out correctly.
# AGENT_QUERY_REQUEST_OWNER=Send a request for release owner message to channel {channel} using the request-release-owner template for version {version} {rc_param}. Ensure the template is filled out correctly.
# AGENT_QUERY_RC_DETAILS=Send RC details message to channel {channel} using the rc-details template for version {version} {rc_param}. Ensure the template is filled out correctly.
# AGENT_QUERY_MISSING_NOTES=Send a missing release notes message to channel {channel} using the missing-release-notes template for version {version} {rc_param}. Ensure that relevant maintainers are pinged and the template is filled out correctly.
# AGENT_QUERY_INTEGRATION_TEST=Send an integration test status message to channel {channel} for version {version} {rc_param}. Format the response well.
# AGENT_QUERY_BROADCAST=Process the following user_query and broadcast the response to channel {channel}. Here is the user_query: {user_query}.

# ============================================================
# COMMUNICATION HANDLER
# ============================================================
# BEDROCK_RESPONSE_MESSAGE_VERSION=1.0
# CHANNEL_MAPPINGS={}
# MESSAGE_TIMEOUT=30
# LOG_LEVEL=INFO

# ============================================================
# GITHUB AGENT
# ============================================================
# VERSION_INCREMENT_AUTHOR=opensearch-trigger-bot
# RELEASE_NOTES_AUTHOR=opensearch-ci-bot
#
# Advisories onboarding target (defaults to opensearch-project/security-advisories)
# ADVISORIES_TARGET_REPO=security-advisories
# ADVISORIES_TARGET_OWNER=opensearch-project
# ADVISORIES_BASE_BRANCH=next
# ADVISORIES_PROJECTS_PATH=config/projects.json
# ADVISORIES_RELEASES_PATH=config/releases-origin-main.json
#
# WSS scan config target (defaults to opensearch-project/opensearch-build)
# WSS_TARGET_REPO=opensearch-build
# WSS_TARGET_OWNER=opensearch-project
# WSS_FILE_PATH=tools/vulnerability-scan/wss-scan.config
#
# Automation app config target (defaults to opensearch-project/automation-app)
# AUTOMATION_APP_TARGET_REPO=automation-app
# AUTOMATION_APP_TARGET_OWNER=opensearch-project
# AUTOMATION_APP_FILE_PATH=configs/resources/opensearch-project-resource.yml

# ============================================================
# GITHUB WEBHOOK HANDLER
# ============================================================
# GITHUB_BOT_USERNAME=oscar-github-agent-test
# MAINTAINER_REQUEST_REPO=opensearch-project/.github
# MAINTAINER_ORG=opensearch-project

# ============================================================
# LOGGING
# ============================================================
# LOG_QUERY_PREVIEW_LENGTH=100

# ============================================================
# METRICS AGENT
# ============================================================
# OPENSEARCH_HOST is stored in Secrets Manager — see agents/metrics/README.md.
# METRICS_CROSS_ACCOUNT_ROLE_ARN=arn:aws:iam::123456789012:role/YourCrossAccountRole
#
# CDK Environment Variables:
# OPENSEARCH_REGION=us-east-1
# OPENSEARCH_SERVICE=es
# OPENSEARCH_LARGE_QUERY_SIZE=1000
# OPENSEARCH_REQUEST_TIMEOUT=60
#
# Agentic Search Pipeline Configuration:
# AGENTIC_PIPELINE=metrics-agentic-pipeline
